{
  "root": "/home/step/certs/root_ca.crt",
  "crt": "/home/step/certs/intermediate_ca.crt",
  "key": "/home/step/secrets/intermediate_ca_key",
  "address": ":9000",
  "dnsNames": ["step-ca", "localhost", "pki.prvis.com"],
  "logger": {"format": "json"},
  "db": {"type": "badgerV2", "dataSource": "/home/step/db"},
  "authority": {
    "provisioners": [
      {
        "type": "ACME",
        "name": "acme",
        "options": {
          "x509": {"defaultDuration": "2160h", "maxDuration": "8760h"}
        }
      },
      {
        "type": "SSHPOP",
        "name": "prvis-ssh",
        "options": {
          "ssh": {"defaultDuration": "720h", "maxDuration": "8760h"}
        }
      },
      {
        "type": "SCEP",
        "name": "fleet-scep",
        "challenge": "${FLEET_SCEP_CHALLENGE}",
        "minimumPublicKeyLength": 2048,
        "options": {
          "x509": {
            "defaultDuration": "8760h",
            "defaultTemplate": {
              "subject": {
                "commonName": "{{ .Token.sub }}",
                "organizationalUnit": ["prvis-mdm"]
              }
            }
          }
        }
      },
      {
        "type": "OIDC",
        "name": "keycloak",
        "clientID": "step-ca",
        "clientSecret": "${STEP_CA_KEYCLOAK_SECRET}",
        "configurationEndpoint": "http://keycloak:8080/realms/prvis/.well-known/openid-configuration",
        "domains": ["prvis.com"],
        "options": {
          "x509": {"defaultDuration": "8760h"},
          "ssh": {"defaultDuration": "720h"}
        }
      }
    ]
  },
  "tls": {
    "minVersion": 1.2,
    "maxVersion": 1.3
  }
}
